// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  MANAGER
  STAFF
}

enum Position {
  SALES_STAFF        // Nhân viên bán hàng
  INTERN             // Nhân viên thử việc
  ASSISTANT_MANAGER  // Cửa hàng phó
  STORE_MANAGER      // Cửa hàng trưởng
}

enum OrderStatus {
  PENDING
  APPROVED
  DELIVERING
  DELIVERED
  REJECTED
}

enum WasteStatus {
  PENDING
  APPROVED
  REJECTED
}

// FIX #4: Đổi Waste.reason từ String sang enum để group report chính xác
enum WasteReason {
  EXPIRED        // Hết hạn sử dụng
  DAMAGED        // Hỏng / Dập nát
  QUALITY_LOSS   // Mất phẩm chất
  CUSTOMER_RETURN // Khách trả
  IMPORT_ERROR   // Lỗi nhập kho
  OTHER          // Khác
}

enum ShiftStatus {
  ASSIGNED
  ABSENT
}

enum InventoryLogType {
  IMPORT
  EXPORT
  WASTE
  ADJUSTMENT
}

// FIX #5: Thêm InventoryStatus để tính toán tập trung ở backend,
// tránh duplicate logic ở nhiều nơi (dashboard, báo cáo, tồn kho page)
enum InventoryStatus {
  OK
  LOW_STOCK      // Dưới minStock — "Sắp hết"
  OUT_OF_STOCK   // quantity = 0 — "Hết hàng"
  EXPIRING_SOON  // Trong vòng 3 ngày tới — "Sắp hết hạn"
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  phone    String?
  role     Role    @default(STAFF)
  position Position @default(SALES_STAFF)

  // FIX #6: Thêm isActive để vô hiệu hoá tài khoản thay vì xoá
  // (xoá sẽ break FK với Order, Waste, ShiftAssignment...)
  isActive Boolean @default(true)

  orders         Order[] @relation("CreatedOrders")
  wastes         Waste[] @relation("CreatedWastes")
  approvedOrders Order[] @relation("ApprovedOrders")
  approvedWastes Waste[] @relation("ApprovedWastes")

  shifts        ShiftAssignment[]
  inventoryLogs InventoryLog[]
  saleRecords   SaleRecord[]

  createdAt DateTime @default(now())
  // FIX #6: Thêm updatedAt để track thay đổi thông tin nhân viên
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// PRODUCT & INVENTORY
// ─────────────────────────────────────────

model Product {
  id       String  @id @default(cuid())
  name     String
  sku      String  @unique
  category String
  unit     String
  price    Decimal @db.Decimal(10, 2)

  imageUrl String?
  isActive Boolean @default(true)
  
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  inventory     Inventory?
  orderItems    OrderItem[]
  wasteItems    WasteItem[]
  inventoryLogs InventoryLog[]
  saleItems     SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inventory {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  minStock Int
  expiry   DateTime?

  // FIX #5: status được tính và cập nhật bởi một background job/service,
  // không nhập tay — đảm bảo nhất quán giữa dashboard, báo cáo, tồn kho page
  status InventoryStatus @default(OK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryLog {
  id        String           @id @default(cuid())
  productId String
  product   Product          @relation(fields: [productId], references: [id])

  type      InventoryLogType
  quantity  Int
  note      String?

  // FIX #3: Thêm FK về Order và Waste để có thể truy vết
  // "tồn kho giảm lúc 10h vì lý do gì" thay vì chỉ dựa vào note string
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  wasteId String?
  waste   Waste?  @relation(fields: [wasteId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────

model Supplier {
  id      String  @id @default(cuid())
  name    String @unique
  contact String?

  products Product[]
  orders   Order[]

  // FIX #11: Thêm timestamps để nhất quán với các model khác
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────

model Order {
  id   String @id @default(cuid())
  // FIX #13: code vẫn giữ @unique nhưng phải được generate ở backend service,
  // không để frontend tự tạo — format: PO-XXXXX (sequential, padded)
  code String @unique

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedOrders", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("ApprovedOrders", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  status      OrderStatus @default(PENDING)

  // FIX #8: totalAmount là denormalized — phải được tính lại đồng bộ
  // trong cùng một transaction khi thêm/xoá/sửa OrderItem
  totalAmount Decimal @db.Decimal(12, 2)

  deliveryDate DateTime?
  receivedAt   DateTime?

  note String?

  items         OrderItem[]
  // FIX #3: Inventory logs có thể reference về Order này
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  receivedQuantity Int @default(0) 
  // price là snapshot tại thời điểm đặt hàng, không phải Product.price hiện tại
  price    Decimal @db.Decimal(10, 2)

  @@unique([orderId, productId])
}

// ─────────────────────────────────────────
// WASTE
// ─────────────────────────────────────────

model Waste {
  id String @id @default(cuid())

  createdById String
  createdBy   User   @relation("CreatedWastes", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("ApprovedWastes", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  status WasteStatus @default(PENDING)

  // FIX #4: Đổi String sang enum để group report không bị lỗi do typo/case
  reason WasteReason

  // FIX #8: totalAmount phải sync với WasteItem — update trong cùng transaction
  totalAmount Decimal @db.Decimal(12, 2)

  note String?

  items         WasteItem[]
  // FIX #3: Inventory logs có thể reference về Waste này
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WasteItem {
  id String @id @default(cuid())

  wasteId String
  waste   Waste  @relation(fields: [wasteId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  // FIX #3 (naming): đổi tên thành amount để nhất quán với OrderItem và Waste.totalAmount
  amount   Decimal @db.Decimal(10, 2)

  @@unique([wasteId, productId])
}

// ─────────────────────────────────────────
// SHIFT
// ─────────────────────────────────────────

model Shift {
  id        String  @id @default(cuid())
  name      String
  code      String  @unique
  startTime Int
  endTime   Int
  color     String?

  assignments ShiftAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShiftAssignment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])

  date DateTime

  // FIX #2: Bỏ dấu ? — không để nullable vì null không có nghĩa rõ ràng,
  // dùng default ASSIGNED thay thế
  status ShiftStatus @default(ASSIGNED)

  // FIX #12: Thêm note để ghi lý do vắng mặt khi status = ABSENT
  note String?

  createdAt DateTime @default(now())

  @@unique([userId, date, shiftId])
}

// ─────────────────────────────────────────
// SALE
// ─────────────────────────────────────────

model SaleRecord {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  totalAmount Decimal  @db.Decimal(12, 2)
  orderCount  Int      @default(0)

  // FIX #1: Thêm createdById — bắt buộc để biết ai tạo/ca nào bán,
  // cần cho báo cáo doanh thu theo nhân viên và audit trail
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  items SaleItem[]

  createdAt DateTime @default(now())
  // FIX #10: Thêm index trên date để query doanh thu theo ngày/tuần/tháng nhanh
  @@index([date])
}

model SaleItem {
  id           String     @id @default(cuid())
  saleRecordId String
  saleRecord   SaleRecord @relation(fields: [saleRecordId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  amount   Decimal @db.Decimal(10, 2)
}

// pnpm dlx prisma migrate dev --name init

// pnpm dlx prisma generate

// pnpm prisma migrate reset